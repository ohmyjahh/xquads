# Opcional: caminho para o aios-core (se nao definido, usa a pasta squads/ local)
# AIOS_CORE_PATH=/Users/rafa/aios-core

# Webhook do Google Apps Script para persistir leads na planilha
# Sem essa var, o write no Sheets e pulado silenciosamente
GOOGLE_SHEETS_WEBHOOK=https://script.google.com/macros/s/AKfycb.../exec

# Webhook do GENE CRM para criar contatos no pipeline com a tag PROMPT
# Sem essa var, o write no GENE e pulado silenciosamente
GENE_WEBHOOK_URL=https://api.genecrm.com.br/webhook/leads/{UUID}
